{
  "name": "nRF Connect SDK v3.3.0",

  // Use the prebuilt image published to GHCR (see .github/workflows/publish-image.yml).
  // The tag matches the NCS version. This makes Codespaces start instantly.
  "image": "ghcr.io/zhixuan2333/ncs-container:v3.3.0",

  // --- Alternative: build locally instead of pulling the prebuilt image ---
  // Comment out "image" above and uncomment this block to build from source.
  // "build": {
  //   "dockerfile": "Dockerfile",
  //   "args": { "NCS_VERSION": "v3.3.0" }
  // },

  "remoteUser": "root",
  "workspaceFolder": "/workspaces/ncs-container",

  // sshd is required for `gh codespace ssh -R` (the reverse tunnel used by
  // scripts/host-bridge.sh to reach your local OpenOCD/serial bridge).
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {}
  },

  "containerEnv": {
    "NCS_VERSION": "v3.3.0",
    "ZEPHYR_BASE": "/opt/ncs/v3.3.0/zephyr",
    "NCS_WORKSPACE": "/opt/ncs/v3.3.0"
  },

  // Ports used by the local OpenOCD/serial bridge (reverse-tunneled in over SSH).
  "forwardPorts": [3333, 4444, 4555],
  "portsAttributes": {
    "3333": { "label": "OpenOCD GDB", "onAutoForward": "ignore" },
    "4444": { "label": "OpenOCD telnet", "onAutoForward": "ignore" },
    "4555": { "label": "Serial bridge", "onAutoForward": "ignore" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "nordic-semiconductor.nrf-connect-extension-pack",
        "marus25.cortex-debug",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/workspaces/ncs-container/scripts"
  }
}
